{
  "expo": {
    "name": "TrufMate",
    "slug": "TrufMate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/trufmatepng.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/trufmatepng.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/trufmatepng.png",
      "bundleIdentifier": "com.trufmate.app"
    },
    "android": {
      "package": "com.trufmate.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/trufmatepng.png",
        "backgroundColor": "#1A1A2E"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/trufmatepng.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "4038e6ec-b703-4f7c-b237-ba2f20ec26a4"
      }
    }
  }
}
